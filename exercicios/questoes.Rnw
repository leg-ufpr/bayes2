#n <- c(50,23,18,29,35,42)
#Y <- c(42,16,15,22,31,34)
#a = 1
#b = 1
#theta = 0.3
integrando <- function(theta, pars, niyi) {
    out <- dbinom(x = niyi[2], size = niyi[1], prob = theta)*
        dbeta(x = theta, shape1 = pars[1], shape2 = pars[2])
    return(out)
}
#for(i in 1:6) {
#    curve(integrando(x, a = 1, b = 1, Y = Y[i], n = n[i]), 0,1, 
#          add = TRUE, ylim = c(0,0.5))
#}
LL <- function(par, dados) {
    ll <- c()
    for(i in 1:nrow(dados)) {
        ll[i] <- integrate(integrando, lower = 0, upper = 1,
                           pars=par, niyi = drop(dados[i,]))$value
    }
##    print(log(ll))
    out <- -sum(log(ll))
    return(out)
}


