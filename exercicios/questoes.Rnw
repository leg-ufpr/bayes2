\item Explique os tópicos a seguir, incluindo exemplos, tendo como referência as aulas e materiais do curso.
\begin{enumerate}
  \item Priori imprópria.
  \item Princípio da verossimilhança.
  \item Reparametrizações, prioris equivalentes e invariância.
\end{enumerate}

  
\item Seja $Y \sim {\rm Gamma}(\alpha, \lambda)$ com priori (independente) $\alpha \sim {\rm Gama}(a, b)$ e $\lambda \sim {\rm Gamma}(c, d)$
  em que $\lambda, b \; {\rm e }\; d$ são parâmetros de taxa.

  \begin{enumerate}
  \item Obtenha a expressão da posteriori $f(\alpha, \lambda|y)$.
  \item Obtenha a expressão da posteriori $f(\lambda|\alpha, y)$.
  \item Obtenha a expressão da posteriori $f(\alpha|\lambda, y)$.
  \item Obtenha a expressão da posteriori $f(\lambda|y)$.
  \item Obtenha a expressão da posteriori $f(\alpha|y)$.
  \item Explique como obter simulações de cada uma das distribuições acima. 
  \item Explique como obter simulações da marginal (preditiva a priori). 
  \item Explique como obter simulações da marginal (preditiva a posteriori). 
  \item Foi proposto o seguinte algorítmo para simular da posteriori conjunta:
    \begin{enumerate}
    \item Escolha um valor inicial para $\alpha$.
    \item Simule um valor de $f(\lambda|\alpha, y)$, em que $\alpha$ é o último valor obtido.
    \item Simule um valor de $f(\alpha|\lambda, y)$, em que $\lambda$ é o último valor obtido.
    \item Repita os dois passos anteriores $N$ vezes.     
    \item Os $N$ pares $\alpha, \lambda$ são uma amostra de $f(\alpha, \lambda|y)$.
    \end{enumerate}
  \end{enumerate}

\begin{solucao}
\paragraph{\bf Solução} \mbox{} \\ 
\begin{itemize}
\item Conjunta
\item Condicionais
\item Marginais
\end{itemize}
\end{solucao} 

<<gamagamagama1, include = FALSE, eval = FALSE>>=
rm(list=ls())
## Priori
## alpha ~ Gamma(a, b)
## lambda ~ Gamma(c, d)
a <- 2; b <- 0.5
c <- 3; d <- 0.5
curve(dgamma(x, a, b), to = 15)
curve(dgamma(x, c, d), to = 15, add = TRUE)
dprior <- function(alp,lam, log = FALSE) {
    res <- dgamma(alp, a, b, log = TRUE) + dgamma(lam, c, d, log = TRUE)
    if(log) return(res)
    else return(exp(res))
}
alpha.seq <- seq(0.1, 10, length = 201)
lambda.seq <- seq(0.1, 10, length = 201)
priori2d <- outer(alpha.seq, lambda.seq, dprior)
image(alpha.seq, lambda.seq, priori2d,
      xlab = expression(alpha), ylab = expression(lambda))
      #axes = TRUE)
contour(alpha.seq, lambda.seq, priori2d,
        xlab = expression(alpha), ylab = expression(lambda))
## Dados
##curve(dgamma(x, 2, 5), to = 2)
##alphaT <- 2; lambdaT <- 5
##set.seed(25)
##n <- 10
##dados <- rgamma(n, alphaT, lambdaT)
y <- c(0.15, 0.38, 0.28, 0.16, 1.64, 0.04, 0.19, 0.34, 0.14, 1.04)
##MASS:fitdistr(dados, "gamma")
## Posteriori (não normalizada)
n <- length(y)
S <- sum(y)
#P <- prod(y)
lP <- sum(log(y))
dpost <- function(alp, lam, log = FALSE){
##    a1 <- (gamma(alp)^(-n)*P^(alp-1)*exp(-b*alp)*lam^(n*alp + c -1)*exp(-(d + S)*lam)
    res <- -n*lgamma(alp) + (alp - 1)*lP + (a-1)*log(alp) - b*alp + (n*alp + c - 1)*log(lam) - (d + S)*lam
    if(log) return(res)
    else return(exp(res))
}
post2d <- outer(alpha.seq, lambda.seq, dpost)
image(alpha.seq, lambda.seq, post2d,
      xlab = expression(alpha), ylab = expression(lambda))
      #axes = TRUE)
contour(alpha.seq, lambda.seq, post2d,
        xlab = expression(alpha), ylab = expression(lambda))
##
contour(alpha.seq, lambda.seq, priori2d, col = "red",
        xlab = expression(alpha), ylab = expression(lambda))
contour(alpha.seq, lambda.seq, post2d, add = TRUE,
        xlab = expression(alpha), ylab = expression(lambda))
## condicionais
dlambda.alpha <- function(lam, alp, log = FALSE){
    dgamma(lam, n*alp + c, d + S, log = log)
}
curve(dlambda.alpha(x, alp = 1.5), to = 10, xlab = expression(lambda), ylab = expression(f(lambda, "|", alpha,y)))
curve(dlambda.alpha(x, alp = 3), to = 10, add = TRUE)
##
dalpha.lambda <- function(alp, lam, log = FALSE){
    res <- -n*lgamma(alp) + (alp - 1)*lP + (a - 1)*log(alp) - b*alp + (n*alp)*log(lam)
    if(log) return(res)
    else return(exp(res))
}
curve(dalpha.lambda(x, 2), to = 5, xlab = expression(f(alpha, "|", lambda,y)))
##
dalpha.y <- function(alp, log = FALSE){
    res <- -n*lgamma(alp) + (alp - 1)*lP + (a - 1)*log(alp) - b*alp - (n*alp+c-1)*log(d+S) + lgamma(n*alp + c)
    if(log) return(res)
    else return(exp(res))    
}
curve(dalpha.y(x), to = 5,
      xlab = expression(alpha), ylab = expression(paste("f(",alpha,"|y)")))

dlambda.y <- Vectorize(function(lam, log = FALSE){
    integrando <- function(alp){
        dpost(alp, lam, log = FALSE)
    }
    res <- integrate(integrando, lower = 0, upper = Inf)$value
    if(log) return(log(res))
    else return(res)
}, "lam")
curve(dlambda.y(x), to = 10,
      xlab = expression(lambda), ylab = expression(paste("f(",lambda, "|y)")))
##
## MCMC para dalpha.y
tunning <- 1
burnin <- 1e3
thinning <- 10
N <- 1e5 + burnin
alpha.sam <- numeric(N)
alpha.sam[1] <- 1
acc <- 0
for(i in 2:N){
    alpha.prop <- rlnorm(1, mean = log(alpha.sam[i-1]), sd = tunning)
    log.r <- dalpha.y(alpha.prop, log = TRUE) - dalpha.y(alpha.sam[i-1], log = TRUE) +
        dlnorm(alpha.sam[i-1], mean = log(alpha.prop), sd = tunning, log = TRUE) -
        dlnorm(alpha.prop, mean = log(alpha.sam[i-1]), sd = tunning, log = TRUE)
##    print(c(alpha.sam[i-1], alpha.prop, exp(log.r)))
    if(alpha.prop <= 0) {
        alpha.sam[i] <- alpha.sam[i-1]
        next
    }
    if(runif(1) < min(1, exp(log.r))){
        alpha.sam[i] <- alpha.prop
        acc <- acc + 1
    }
    else alpha.sam[i] <- alpha.sam[i-1]
}
cat("Taxa de aceitação:", acc/(N-1), "\n")

alpha.sam <- alpha.sam[-(1:burnin)]
plot(acf(alpha.sam))
length(alpha.sam)
alpha.sam <- alpha.sam[seq(1, length(alpha.sam), by = thinning)]
length(alpha.sam)
plot(acf(alpha.sam))
## Simulando lambda|alpha,y
lambda.sam <- rgamma(length(alpha.sam), n*alpha.sam + c, d + S)

## Gráficos
plot(alpha.sam, lambda.sam, pch = 20, cex = 0.5,
     xlab = expression(alpha), ylab = expression(lambda))
contour(alpha.seq, lambda.seq, post2d, add = TRUE, lwd = 2,
        xlab = expression(alpha), ylab = expression(lambda))
##
## Gibbs para a posteriori conjunta
##  1. amostra de alpha|lambda,y (MCMC)
##  2. amostra de lambda|alpha,y (direto)
N <- 1e5
tunning <- 0.5
burnin <- 1e3
thinning <- 10
acc <- 0
alpha.gibbs <- numeric(N)
lambda.gibbs <- numeric(N)
alpha.gibbs[1] <- 1
lambda.gibbs[1] <- 1

acc <- 0
for(i in 2:N){
    ## alpha|lambda,y (MCMC)
    alpha.prop <- rlnorm(1, mean = log(alpha.gibbs[i-1]), sd = tunning)
    log.r <- dalpha.lambda(alpha.prop, lambda.gibbs[i-1], log = TRUE) - 
        dalpha.lambda(alpha.gibbs[i-1], lambda.gibbs[i-1], log = TRUE) +
        dlnorm(alpha.gibbs[i-1], mean = log(alpha.prop), sd = tunning, log = TRUE) -
        dlnorm(alpha.prop, mean = log(alpha.gibbs[i-1]), sd = tunning, log = TRUE)
    if(runif(1) < min(1, exp(log.r))){
        alpha.gibbs[i] <- alpha.prop
        acc <- acc + 1
    }
    else alpha.gibbs[i] <- alpha.gibbs[i-1]
    ## lambda|alpha,y (direto)
    lambda.gibbs[i] <- rgamma(1, n*alpha.gibbs[i] + c, d + S)
}
cat("Taxa de aceitação:", acc/(N-1), "\n")
alpha.gibbs <- alpha.gibbs[-(1:burnin)]
lambda.gibbs <- lambda.gibbs[-(1:burnin)]
plot(acf(alpha.gibbs))
plot(acf(lambda.gibbs))
length(alpha.gibbs)
alpha.gibbs <- alpha.gibbs[seq(1, length(alpha.gibbs), by = thinning)]
lambda.gibbs <- lambda.gibbs[seq(1, length(lambda.gibbs), by = thinning)]
length(alpha.gibbs)
plot(acf(alpha.gibbs))
plot(acf(lambda.gibbs))

plot(alpha.gibbs, lambda.gibbs, pch = 20, cex = 0.5,
     xlab = expression(alpha), ylab = expression(lambda))
contour(alpha.seq, lambda.seq, post2d, add = TRUE, lwd = 2)
##
## Comparando marginais obtidas pelos 2 métodos/algorítmos
##
plot(density(alpha.sam), col = "red", lwd = 2,
     xlab = expression(alpha), ylab = expression(f(alpha, "|", y)))
lines(density(alpha.gibbs), col = "blue", lwd = 2)

plot(density(lambda.sam), col = "red", lwd = 2,
     xlab = expression(lambda), ylab = expression(f(lambda, "|", y)))
lines(density(lambda.gibbs), col = "blue", lwd = 2)
@ 

<<gamagamagama2, include = FALSE, eval = FALSE>>=
require(rjags)
require(coda)

modeloGama <- "
model {
  # Verossimilhança
    for (i in 1:n) {
        y[i] ~ dgamma(alpha, lambda)
    }
  # Prioris
  alpha ~ dgamma(a, b)
  lambda ~ dgamma(c, d)
}
"
dados <- list(y = y, n = n,
              a = a, b = b,
              c = c, d = d)

modeloGama.jags <- jags.model(
    textConnection(modeloGama),
    data = dG,
    n.chains = 3,
    n.adapt = 100,
    inits = list(
        list(alpha = 1, lambda = 3),
        list(alpha = 2, lambda = 2),
        list(alpha = 3, lambda = 0.5)
    ),
    quiet = TRUE
)
update(modeloGama.jags, 1000) # Burn-in
amsGama <- coda.samples(
    modeloGama.jags,
    variable.names = c("alpha", "lambda"),
    n.iter = 10000,
    thin = 10
)
str(amsGama)
print(summary(amsGama))
plot(amsGama)
amsG <- as.matrix(amsGama)

acf(amsG[, "alpha"])
acf(amsG[, "lambda"])

plot(amsGama, trace = FALSE)


## Comparando marginais obtidas pelos 3 métodos/algorítmos
## para alpha
## - amostragem exata
plot(density(alpha.sam), col = "red",
     xlab = expression(alpha), ylab = expression(paste("f(",alpha,"|, y)")))
## - MCMC Gibbs (código)
lines(density(alpha.gibbs), col = "blue", lwd = 2)
## MCMC JAGS
lines(density(amsG[, "alpha"]), col = "darkgreen", lwd = 3)

## para lambda
plot(density(lambda.sam), lwd = 1,
     xlab = expression(lambda), ylab = expression(paste("f(",lambda, "|, y)")))
lines(density(lambda.gibbs), col = "blue", lwd = 2)
lines(density(amsG[, "lambda"]), col = "darkgreen", lwd = 3)
@

\item  Um teste para detectar a presença ou não de certa doença é aplicado em uma população. Sabe-se que o teste acerta 90\% dos que possuem a doença ({\it sensibilidade}) e 80\% dos que não a possuem ({\it especificidade}). A ocorrência da doença na população alvo é de 2\% ({\it prevalência}).
O interesse é realizar uma análise bayesiana completa. Pede-se, explicando passo a passo:
\begin{enumerate}
\item {\bf Análise da Posteriori:} Determinar a probabilidade de um indivíduo ter a doença, dado um resultado positivo ({\it valor preditivo positivo}), e a probabilidade de não ter a doença, dado um resultado negativo ({\it valor preditivo negativo}).
\item {\bf Análise pelo Fator de Bayes:} Avaliar a força da evidência fornecida por um teste positivo em favor da hipótese de que o paciente tem a doença, em comparação com a hipótese de que não a tem.
\item {\bf Análise pela Teoria da Decisão:} Suponha que a perda (ou custo) de um diagnóstico {\it falso negativo} (diagnosticar "não doente" quando a pessoa tem a doença) seja 5 vezes maior que a perda de um diagnóstico {\it falso positivo} (diagnosticar "doente" quando a pessoa não tem a doença). Qual seria a decisão ótima entre diagnosticar como 'Doente' ou 'Não Doente' para cada resultado do teste, a fim de minimizar a perda esperada?
\item Discuta os resultados.
\item Discuta as características de cada e as diferenças dos métodos.
\end{enumerate}

<<include = FALSE>>=
TD.f <- function(prev, sens, esp, FN.FP){
    pr <- c(th0 = 1-prev, th1 = prev) 
    M <- rbind(th0 = c(y0 = esp, y1 = 1-esp), th1 = c(1-sens, sens))
    CJ <- pr * M
    post <- prop.table(CJ, mar = 2)
    py <- colSums(CJ)
    ##
    BF01y0 <- esp/(1-sens)
    BF01y0.class <- cut(log10(BF01y0),
        breaks = c(-Inf, 0, 1/2, 1, 3/2, 2, Inf),
        labels = c("sem evidencia para H0", "mal vale mencionar", "substancial", "forte", "muito forte", "decisiva")
        )
    BF10y1 <- sens/(1-esp)
    BF10y1.class <- cut(log10(BF10y1),
        breaks = c(-Inf, 0, 1/2, 1, 3/2, 2, Inf),
        labels = c("sem evidencia para H1", "mal vale mencionar", "substancial", "forte", "muito forte", "decisiva")
        )
    ##
    L <- matrix(c(0, 1, FN.FP, 0), nrow = 2)
    dimnames(L) <- list(
        decisao = c("Não Doente", "Doente"),
        th = c(0, 1)
    )
    post
    EL <- L%*%post
    minEL <- apply(EL, 2, min)
    names(minEL) <- rownames(EL)[apply(EL, 2, which.min)]
    list(
        post = post,
        py = py,
        BF = c(BF01y0 = BF01y0, BF10y1 = BF10y1),
        EL = EL,
        minEL = minEL,
        decisao = names(minEL)
    )
    RB <- drop(crossprod(minEL, py))
    return(list(
        post = post,
        py = py,
        BF = c(BF01y0 = BF01y0, BF10y1 = BF10y1),
        BF.class = c(BF01y0 = as.character(BF01y0.class),
                     BF10y1 = as.character(BF10y1.class)),
        EL = EL,
        decisao = minEL,
        RB = RB
    ))
}
(foo <- TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = 5))
TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = 10)
TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = 10)
TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = 11)

## Exemplo 5.2 do material:
TD.f(prev = 0.10, sens = 0.9, esp = 0.85, FN.FP = 10)

## encontrar razão de custos que muda decisão:
fun1 <- function(FN.FP){
    res <- TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = FN.FP)
    res$EL[, "y1"]
}
bal <- t(sapply(c(1:20), fun1))
matplot(1:20, bal, type = "l")

fun2 <- function(FN.FP){
    res <- TD.f(prev = 0.02, sens = 0.9, esp = 0.8, FN.FP = FN.FP)
    abs(diff(res$EL[, "y1"]))
}
optimize(fun2, interval = c(1, 20))
@ 

\item Considere o contexto predição (a posteriori) Bayesiana, porém deseja-se obter somente o valor esperado e a variância da preditiva. Obtenha as expressões destas quantidades no modelo
  de verossimilhança Poisson com priori Gamma.

\item Explique de forma concisa a diferença entre intervalos frequentista, de verossimilhança e bayesiano (de quantis e HDI)


\item Descreva o modelo sendo ajustado, distribuições envolvidas, parâmetros e constantes.
  Esboce ainda a estrutura dos dados nas seguintes declarações de modelos em JAGS.

\begin{enumerate}

  \item
\begin{verbatim}
model{
  for (i in 1:N){
    x[i] ~ dbern(p)
  }
  p ~ dbeta(alpha, beta)
  alpha <- 1
  beta <- 1
}
\end{verbatim}

  \item
\begin{verbatim}
model {
  for (i in 1:n) {
    y[i] ~ dnorm(0, tau)
  }
  tau ~ dgamma(a, b) 
  sigma <- 1 / sqrt(tau)
}
\end{verbatim}

\item
\begin{verbatim}
model{
  for(i in 1:M){
     for(j in 1:N){
        y[i,j] ~ dnorm(mu[i], tau)
     }
     mu[i] ~ dnorm(theta, tauD)
  }
  tau <- pow(sigma, -2)
  sigma ~ dunif(0, 100)
  theta ~ dnorm(0, .001)
  tauD <- pow(delta, -2)
  delta ~ dunif(0, 100)
}
\end{verbatim}

\item
\begin{verbatim}
model {
    for (i in 1:n) {
        y[i] ~ dgamma(alpha, lambda)
    }
  alpha ~ dgamma(a, b)
  lambda ~ dgamma(c, d)
}

\end{verbatim}

\item
\begin{verbatim}
model {
  y ~ dbin(theta, n)
  k ~ dcat(p)
  theta ~ dbeta(alpha[k], beta[k])
}
\end{verbatim}

\item
\begin{verbatim}
model{
for(i in 1:n){
    y[i] ~ dpois(mu[i])
    mu[i] <- ifelse(i > k, lambda, theta)
}
k ~ dcat(ano[])
theta ~ dgamma(a1, b1)
lambda ~ dgamma(a2, b2)
dif <- lambda - theta
ib1 ~ dgamma(c1, d1)
b1 <- 1/ib1
ib2 ~ dgamma(c2, d2)
b2 <- 1/ib2
a1 <- 0.5
a2 <- 0.5
c1 <- 0.1
c2 <- 0.1
d1 <- 1
d2 <- 1
}
\end{verbatim}
\end{enumerate}



\end{enumerate}

