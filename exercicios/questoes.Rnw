## bayes empírico com estimação por momentos
hp.mom <- function(dados, weighted = TRUE){
    ## dados é matrix Nx2  
    th.i <- dados[,2]/dados[,1]
    if(!weighted){
        mth <- mean(th.i)
        vth <- var(th.i)
    }
    else{
        mth <- sum(dados[,2])/sum(dados[,1])
        vth <- (sum(dados[,1]*(th.i - mth)^2)/sum(dados[,1])) #- mth/mean(dados[,1])
    }
    a <- (((1-mth)*mth^2)/vth) - mth
    b <- a*(1-mth)/mth
    return(c(a,b))
}
(emp.mw <- hp.mom(ny))
(emp.m <- hp.mom(ny, weighted=FALSE))
curve(dbeta(x, emp.m[1]+sny[2], emp.m[2]+sny[1]-sny[2]), from=0, to=1, n=2000)
curve(dbeta(x, sny[2], sny[1]-sny[2]), from=0, to=1, col=4, add=T, n=2000)
curve(dbeta(x, emp.mw[1], emp.mw[2]), from=0, to=1, add=T, col=2, n=2000)
curve(dbeta(x, emp.m[1], emp.m[2]), from=0, to=1, add=T, col=3, n=2000)

