\item Considere o problema de uma regressão linear simples usual com o regressor $x$ e a variável resposta $Y$.
Deseja-se implementar um algorítmo para análise bayesiana deste modelo.
Descreva os passos que seriam necessários e
obtenha as expressões relevantes para implementação do algorítmo. 
Inclua no algoritmo a possibilidade de predição.
Faça escolhas qdo necessário como, por exemplo, de priori.

% \item Escreva de maneira suscinta (um parágrafo com no máximo 10 linhas) como voce explicaria para um 
%   pesquisador de outra área as características da análise bayesiana em contraste com outra(s) abordagem(ens).

\item A classificação de qualidade de um componente elétrico é excelente ($y = 1$), bom ($y = 2$) ou ruim ($y = 3$). A probabilidade de vários níveis de qualidade dependem da fábrica onde é produzido ($\theta_1 = 0$: fábrica A, $\theta_1 = 1$: fábrica B) e do tipo de máquina ($\theta_2 = 0$: máquina I, $\theta_2 = 1$: máquina II, $\theta_2 = 2$: máquina III). As probabilidades para $y = 2$ são dadas pela Tabela~\ref{tab:exerc1a-cap4}.
Além disso, distribuição conjunta de $(\theta_1, \theta_2)$ é dada na Tabela~\ref{tab:exerc1b-cap4}.
Encontre a distribuição posteriori conjunta de $\theta_1, \theta_2|y = 2$ e cada uma das distribuições marginais. Tendo observado $y = 2$:
\begin{enumerate}
\item Qual a combinação fábrica/máquina é a mais provável de ter produzido esse componente?
\item Qual a distribuição posteriori (conjunta)?
\item Quais são as distribuições marginais?
\item E as condicionais?  
\item Esboce gráficos para os itens anteriores
\end{enumerate}

%%
%% 2025 prova 2
%%

\item Seja $Y$ uma variável aleatória com distribuição normal de média igual a zero
  e precisão $\tau$ sendo $\tau = 1/\sigma^2$. Será tomada uma amostra de $n$ observações
  $y_1, y_2, \ldots y_n$ deste modelo.
  \begin{enumerate}
  \item Qual a priori conjugada para $\tau$?
  \item Qual é a distribuição posteriori para a priori do item anterior?
  \item Qual a priori de Jeffreys $\tau$?
  \item Qual é a distribuição posteriori para a priori de Jeffreys?
  \end{enumerate}

\begin{solucao}
\paragraph{\bf Solução} \mbox{} \\
  \begin{itemize}
  \item Priori conjugada: $\tau \sim {\rm Gama}(a, b):$ 
    \[
      \pi(\tau) \propto \tau^{a-1} e^{-b\tau}.
    \]
    
  \item Posteriori para priori conjugada
    \[
      \tau|y \sim \mathrm{Gama}\left(a + \frac{n}{2},\; b + \frac{1}{2} \sum_{i=1}^n y_i^2\right).
    \]
  \item Priori de Jeffreys
    \[
      \pi_J(\tau) \propto 1/\tau.
    \]
  \item Posteriori para priori de Jeffreys
    \[
      \pi(\tau|y) \propto \tau^{n/2 - 1} \exp\left(-\frac{\tau}{2} \sum y_i^2\right).
    \]
  \end{itemize}
\end{solucao}


<<normal-precisao-jags, include = FALSE>>=
library(rjags)
library(coda)

rm(list=ls())
a <- 0.1
b <- 0.1
curve(dgamma(x, a, b), from=0, to=5, col="red", lwd=2,
      xlab=expression(tau), ylab=expression(f(tau)))

set.seed(2025)
n <- 15
tau <- 2 
y <- round(rnorm(n, mean=0, sd=sqrt(1/tau)), dig=2)
y

## itens a, b) Modelo JAGS com Priori Conjugada (Gama)
modelo1 <- "
model {
  ## Verossimilhança
  for (i in 1:n) {
    y[i] ~ dnorm(0, tau)
  }
  ## Priori
  tau ~ dgamma(a, b) 
  ## Parâmetro derivado (desvio padrão)
  sigma <- 1 / sqrt(tau)
}
"
dados <- list(y = y, n = n, a = a, b = b)

modelo1.jags <- jags.model(
    textConnection(modelo1),
    data = dados,
    n.chains = 3,
    n.adapt = 100,
    inits = list(
        list(tau = 1),
        list(tau = 0.5),
        list(tau = 2)
    ),
    quiet = TRUE
)

update(modelo1.jags, 1000) # Burn-in

ams1 <- coda.samples(
  modelo1.jags,
  variable.names = c("tau", "sigma"),
  n.iter = 10000,
  thin = 10
)
str(ams1)
str(as.matrix(ams1))
print(summary(ams1))
plot(ams1)
acf(as.matrix(ams1)[, "tau"])

##print(gelman.diag(ams1))
##gelman.plot(ams1)

plot(ams1, trace = FALSE)
plot(density(as.matrix(ams1)[, "tau"]))

## Teóricas: resultados analíticos
curve(dgamma(x, a, b), to=10, col=2, lwd=2, add=TRUE)
n <- length(y)
Sy2 <- sum(y^2)
a.post <- a + n/2
b.post <- b + Sy2/2
curve(dgamma(x, a.post, b.post), to= 10, col=4, lwd=2, add=TRUE)

## itens c, d) Modelo JAGS com Priori de Jeffreys
## JAGS não aceita priori imprópria
## Alternativas:
## 1. usar priori Gama com parâmetros pequenos (0.001, 0.001)
## 2. Priori uniforme em log(tau) (reparametrização/truncada)
## 3. Usar outro software (Stan, NIMBLE, etc)

modelo2 <- "
model {
  # Verossimilhança
  for (i in 1:n) {
    y[i] ~ dnorm(0, tau)
  }
  # Priori de Jeffreys (aproximada)
  tau ~ dgamma(a, b)
  # Função do parâmetro/reparametrização
  sigma <- 1/sqrt(tau)
}
"

dados <- list(y = y, n = n, a = 0.001, b = 0.001)

modelo2.jags <- jags.model(
    textConnection(modelo2),
    data = dados,
    n.chains = 3,
    n.adapt = 100,
    inits = list(
        list(tau = 1),
        list(tau = 0.5),
        list(tau = 2)
    ),
    quiet = TRUE
)
update(modelo2.jags, 1000) # Burn-in
ams2 <- coda.samples(
    modelo2.jags,
    variable.names = c("tau", "sigma"),
    n.iter = 10000,
    thin = 10
)

str(ams2)
print(summary(ams2))
plot(ams2)
acf(as.matrix(ams2)[, "tau"])
##print(gelman.diag(ams1))
##gelman.plot(ams1)

plot(ams2, trace = FALSE)
plot(density(as.matrix(ams2)[, "tau"]))

## Teóricas: resultados analíticos
curve(dgamma(x, 0.001, 0.001), to=10, col=2, lwd=2, add=TRUE)
n <- length(y)
Sy2 <- sum(y^2)
a.post <- 0 + n/2
b.post <- 0 + Sy2/2
curve(dgamma(x, a.post, b.post), to= 10, col=4, lwd=2, add=TRUE)
@


\item Seja uma variável aleatória $Y$ e o seguinte modelo de probabilidades: $Y|\theta \sim {\rm Bin}(n, \theta)$.
  Adota-se como priori de $\theta$ uma mistura das distribuições ${\rm Beta}(2, 10)$ e $ {\rm Beta}(4, 2)$ com pesos 0,20 e 0,80, respectivamente.
  Uma amostra forneceu $y = 6, n = 20$. Esboce os gráficos de cada componentes da priori. Obtenha a expressão da posteriori e um esboço do seu gráfico.

\begin{solucao}
\paragraph{\bf Solução} \mbox{} \\
  Priori:
  \[ P(\theta) = 0.20 * Beta(2,10) + 0.80 * Beta(4,2).\]
  Observou-se \(y=6, n=20\). Verossimilhança:
  \[ L(\theta|y) \propto \theta^6 (1-theta)^{20-6}. \]
  Posteriori:
  \[ P(\theta) = 0.4159 * Beta(8,24) + 0.5841 * Beta(10,16).\]

\end{solucao}
  
<<mistura1, include = FALSE>>=
rm(list=ls())
n <- 20
y <- 6
a1 <- 2
b1 <- 10
a2 <- 4
b2 <- 2
w1.pri <- 0.2
w2.pri <- 0.8
w1.pos <- w1.pri * beta(y+a1,n-y+b1)/beta(a1,b1)
w2.pos <- w2.pri * beta(y+a2,n-y+b2)/beta(a2,b2)
pos1 <- w1.pos/(w1.pos + w2.pos)
pos2 <- w2.pos/(w1.pos + w2.pos)
ppos <- c(pos1, pos2)
fpri <- function(x) w1.pri*dbeta(x, a1, b1) + w2.pri*dbeta(x, a2, b2)
fpos <- function(x) pos1*dbeta(x, y+a1, n-y+b1) + pos2*dbeta(x, y+a2, n-y+b2)
fvero <- function(x) dbeta(x, y+1, n-y+1)
curve(fvero, from=0, to=1, n=1001, col=4, lty=2, lwd=2,
            xlab=expression(theta), ylab=expression(paste("f(",theta,")")))
curve(fpos, from=0, to=1, n=1001, col=1, lty=1, lwd=2, add = TRUE)
curve(fpri, from=0, to=1, n=1001, col=2, lty=1, lwd=2, add=TRUE)
legend("topright", c("Verossimilhança","Posteriori","Priori"), lwd = 2, lty=c(2,1,1), col=c(4,1,2), cex=0.7)
##
curve(dbeta(x, 2, 10), col = "red", lty = 2)
curve(dbeta(x, 4, 2), col = "red", lty = 2, add = TRUE)
fprior <- function(x) 0.2*dbeta(x, 2, 10) + 0.8*dbeta(x,4,2)
curve(fprior, col = "red", lwd = 2, add = TRUE)
w1 <- 0.2 * beta(8,24)/beta(2,10)
w2 <- 0.8 * beta(10,16)/beta(4,2)
p1 <- w1/(w1+w2)
p2 <- w2/(w1+w2)
fpost <- function(x) p1*dbeta(x, 8, 24) + p2*dbeta(x,10,16)
curve(fpost, add = T, lwd = 2)
##
## simulando da posteriori
N <- 1e6
comp <- sample(1:2, N, prob = c(p1, p2), replace = TRUE)
theta.sam <- rbeta(N, c(a1+y, a2+y)[comp], c(b1+n-y, b2+n-y)[comp])
lines(density(theta.sam), lwd = 2, col = 4)
@

<<mistura1-jags, include = FALSE>>=
modeloMistura <- "
model {
  # Verossimilhança
  y ~ dbin(theta, n)
  # Priori de Mistura
  k ~ dcat(p)
  theta ~ dbeta(alpha[k], beta[k])
}
"
dados <- list(
    y = 6, n = 20,
    p = c(0.2, 0.8),
    alpha = c(2, 4), beta = c(10, 2)
)

mistura.jags <- jags.model(
  textConnection(modeloMistura),
  data = dados,
  n.chains = 3,
  n.adapt = 100,
  inits = list(
      list(k = 1, theta = 0.5),
      list(k = 2, theta = 0.5),
      list(k = 1, theta = 0.5)
  ),
  quiet = TRUE
)
update(mistura.jags, 1000)
amsMistura <- coda.samples(
    mistura.jags,
    variable.names = c("theta", "k"),
    n.iter = 5000,
    thin = 5
)

print(summary(amsMistura))
plot(amsMistura)

ams.m <- as.matrix(amsMistura)
names(ams.m)
prop.table(table(ams.m[, "k"]))
acf(ams.m[, "theta"])

curve(dbeta(x, 2, 10), col = "red", lty = 3)
curve(dbeta(x, 4, 2), col = "red", lty = 3, add = TRUE)
curve(fprior, col = "red", lwd = 2, add = TRUE)
curve(fpost, add = T, lwd = 2)
lines(density(ams.m[, "theta"]), col = "blue", lwd = 2)
@


