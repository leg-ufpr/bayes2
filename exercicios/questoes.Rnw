dpred <- function(yp, np, sn, sy, a, b, log=FALSE){
    ## np : n para predição
    ## sy : \sum y_i , sn : \sum n_i
    ## a, b : hiperparâmetros
    a1 <- a+sy
    b1 <- b+sn-sy
    res <- lchoose(np, yp) - lbeta(a1,b1)  + lbeta(yp+a1,np-yp+b1)
    if(log) return(res)
    else return(exp(res))
}
dpred(25, np=30, sn = sny[1], sy=sny[2], a=a0, b=b0)
dpred(25:30, np=30, sn = sny[1], sy=sny[2], a=a0, b=b0)
sum(dpred(0:30, np=30, sn = sny[1], sy=sny[2], a=a0, b=b0))
plot(0:30, dpred(0:30, np=30, sn = sny[1], sy=sny[2], a=a0, b=b0), ty="h")
